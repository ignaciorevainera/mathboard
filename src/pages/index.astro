---
import BaseLayout from "../layouts/BaseLayout.astro";
import ShortcutsSection from "../components/sections/ShortcutsSection.astro";
import ImportantDocumentsSection from "../components/sections/ImportantDocumentsSection.astro";
import SyllabusSection from "../components/sections/SyllabusSection.astro";
import {
  getTopicCardsForHome,
  getTopicShortcutsForHome,
} from "../lib/topic-content";

const [shortcuts, topicCards] = await Promise.all([
  getTopicShortcutsForHome(9),
  getTopicCardsForHome(),
]);
---

<BaseLayout
  title="Mathboard · Dashboard"
  description="Math topics catalog with quick shortcuts and per-block subtopic access."
>
  <h1 class="sr-only">Catálogo de temas y subtemas de matemáticas</h1>
  <ImportantDocumentsSection />
  <ShortcutsSection shortcuts={shortcuts} />
  <SyllabusSection topics={topicCards} />
</BaseLayout>
