---
import BaseLayout from "../layouts/BaseLayout.astro";
import ImportantResourcesSection from "../components/sections/ImportantResourcesSection.astro";
import SyllabusSection from "../components/sections/SyllabusSection.astro";
import { getTopicGroupsForHome } from "../lib/topic-content";

const topicGroups = await getTopicGroupsForHome();
---

<BaseLayout
  title="Mathboard · Dashboard"
  description="Math topics catalog with grouped blocks and downloadable support resources."
>
  <h1 class="sr-only">Catálogo de temas y subtemas de matemáticas</h1>
  <SyllabusSection groups={topicGroups} />
  <ImportantResourcesSection />
</BaseLayout>
