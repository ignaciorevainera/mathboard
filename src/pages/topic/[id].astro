---
import { render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import TopicMarkdownContentSection from "../../components/sections/TopicMarkdownContentSection.astro";
import { getTopicDetailById, getTopicIds } from "../../lib/topic-content";

export async function getStaticPaths() {
  const ids = await getTopicIds();

  return ids.map((id) => ({
    params: { id },
  }));
}

const { id } = Astro.params;
const topic = id ? await getTopicDetailById(id) : undefined;

if (!topic) {
  throw new Error(`Topic not found: ${id ?? "unknown"}`);
}

const { Content, headings } = await render(topic);
---

<BaseLayout
  title={`Mathboard · ${topic.data.title}`}
  description={topic.data.description}
  enableMath
>
  <TopicMarkdownContentSection
    title={topic.data.title}
    description={topic.data.description}
    icon={topic.data.icon}
    headings={headings}
  >
    <Content />
  </TopicMarkdownContentSection>
</BaseLayout>
