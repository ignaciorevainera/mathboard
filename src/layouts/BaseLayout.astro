---
import "../styles/global.css";
import Navbar from "../components/global/Navbar.astro";
import Footer from "../components/global/Footer.astro";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  enableMath?: boolean;
}

const {
  title,
  description,
  ogImage = "https://placehold.co/1200x630",
  enableMath = false,
} = Astro.props;
---

<html lang="es" data-theme="light">
  <head>
    <script is:inline>
      const THEME_KEY = "mathboard-theme";
      const LEGACY_THEME_KEY = "theme";
      const DEFAULT_THEME = "light";
      const ENABLED_THEMES = new Set(["light", "night"]);

      const savedTheme =
        localStorage.getItem(THEME_KEY) ?? localStorage.getItem(LEGACY_THEME_KEY);
      const resolvedTheme = ENABLED_THEMES.has(savedTheme)
        ? savedTheme
        : DEFAULT_THEME;

      if (localStorage.getItem(THEME_KEY) !== resolvedTheme) {
        localStorage.setItem(THEME_KEY, resolvedTheme);
      }

      document.documentElement.setAttribute("data-theme", resolvedTheme);
    </script>
    <script>
      import { themeChange } from "theme-change";
      themeChange(false);
      // 👆 you could import the CDN directly instead of these two lines
    </script>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    {
      enableMath && (
        <>
          <link
            rel="stylesheet"
            href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css"
            integrity="sha384-nB0miv6/jRmo5UMMR1wu3Gz6NLsoTkbqJghGIsx//Rlm+ZU03BU6SQNC66uf4l5+"
            crossorigin="anonymous"
          />
          <script
            is:inline
            defer
            src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.js"
            integrity="sha384-7zkQWkzuo3B5mTepMUcHkMB5jZaolc2xDwL6VFqjFALcbeS9Ggm/Yr2r3Dy4lfFg"
            crossorigin="anonymous"
          ></script>
          <script
            is:inline
            defer
            src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/contrib/auto-render.min.js"
            integrity="sha384-43gviWU0YVjaDtb/GhzOouOXtZMP/7XUzwPTstBeZFe/+rCMvRwr4yROQP43s0Xk"
            crossorigin="anonymous"
          ></script>
          <script is:inline>
            document.addEventListener("DOMContentLoaded", () => {
              if (typeof renderMathInElement === "function") {
                renderMathInElement(document.body, {
                  delimiters: [
                    { left: "$$", right: "$$", display: true },
                    { left: "$", right: "$", display: false },
                    { left: "\\(", right: "\\)", display: false },
                    { left: "\\[", right: "\\]", display: true },
                  ],
                  throwOnError: false,
                });
              }
            });
          </script>
        </>
      )
    }
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
  </head>
  <body class="min-h-screen bg-base-100 text-base-content">
    <Navbar />
    <main class="flex-1 min-h-svh grow">
      <slot />
    </main>
    <Footer />
  </body>
</html>
