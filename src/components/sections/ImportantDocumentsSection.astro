---
import SectionWrapper from "../ui/SectionWrapper.astro";
import { Icon } from "astro-icon/components";
---

<SectionWrapper id="important-documents">
  <div class="rounded-2xl border border-base-300 bg-base-200/70 p-6 md:p-8">
    <div
      class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between"
    >
      <div class="space-y-2">
        <h2 class="text-3xl font-semibold md:text-4xl">
          Documentos importantes
        </h2>
        <p class="text-base-content/80">
          Accedé a tablas de consulta rápida para derivadas, integrales e
          identidades trigonométricas.
        </p>
      </div>
      <a href="/documents" class="btn btn-primary gap-2">
        Ver documentos
        <Icon name="tabler:arrow-right" aria-hidden="true" class="size-4" />
      </a>
    </div>
  </div>
</SectionWrapper>
