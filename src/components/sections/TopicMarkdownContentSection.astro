---
import { Icon } from "astro-icon/components";
import SectionWrapper from "../ui/SectionWrapper.astro";

interface Props {
  title: string;
  description: string;
  icon: string;
  headings: Array<{
    depth: number;
    slug: string;
    text: string;
  }>;
}

const { title, description, icon, headings } = Astro.props;

const tocHeadings = headings.filter(
  (heading) =>
    (heading.depth === 2 || heading.depth === 3) &&
    heading.slug &&
    heading.text.trim().length > 0,
);
---

<SectionWrapper>
  <a href="/#syllabus" class="btn btn-ghost btn-sm w-fit">Volver al temario</a>
  <div class="grid gap-8 lg:grid-cols-12">
    <div id="topic-content" class="space-y-8 lg:col-span-8">
      <header
        class="relative overflow-hidden rounded-3xl border border-base-300 bg-base-200/70 p-8 md:p-10"
      >
        <div
          aria-hidden="true"
          class="absolute right-4 top-4 size-28 rounded-full bg-primary/20 blur-2xl"
        >
        </div>
        <div class="relative z-10 flex items-center gap-4">
          <div class="rounded-2xl bg-primary/15 p-4 text-primary shadow-sm">
            <Icon name={icon} aria-hidden="true" class="size-8" />
          </div>
          <div>
            <h1 id="topic-title" class="font-display text-3xl md:text-5xl">
              {title}
            </h1>
            <p class="mt-2 max-w-prose text-base-content/80">{description}</p>
          </div>
        </div>
      </header>

      <article class="card border border-base-300 bg-base-100 shadow-sm">
        <div class="card-body">
          <div
            class="prose prose-base max-w-none prose-headings:font-display prose-headings:text-base-content prose-p:text-base-content/85 prose-li:text-base-content/85 prose-strong:text-base-content prose-a:text-primary prose-table:text-sm prose-th:text-base-content prose-td:text-base-content/85"
          >
            <slot />
          </div>
        </div>
      </article>
    </div>

    <aside class="lg:col-span-4 lg:sticky lg:top-24 lg:self-start">
      <nav class="rounded-2xl" aria-label="En esta pagina">
        <div class="flex flex-col gap-4 lg:max-h-screen">
          <h2 class="card-title text-xl">En esta pagina</h2>
          {
            tocHeadings.length > 0 && (
              <ul class="menu p-0 lg:min-h-0 lg:flex-1 lg:overflow-y-auto">
                {tocHeadings.map((heading) => (
                  <li>
                    <a
                      href={`#${heading.slug}`}
                      class:list={[
                        "rounded-lg transition-colors hover:bg-neutral/10 hover:text-base-content",
                        heading.depth === 2
                          ? "px-3 py-2 text-sm font-semibold leading-snug text-base-content/80"
                          : "ml-3 px-3 py-1.5 text-sm leading-snug text-base-content/65",
                      ]}
                    >
                      {heading.text}
                    </a>
                  </li>
                ))}
              </ul>
            )
          }
        </div>
      </nav>
    </aside>
  </div>
</SectionWrapper>
