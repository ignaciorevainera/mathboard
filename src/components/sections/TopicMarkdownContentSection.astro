---
import { Icon } from "astro-icon/components";
import SectionWrapper from "../ui/SectionWrapper.astro";
import {
  getTopicHaloToneClasses,
  getTopicIconToneClasses,
  type TopicVariant,
} from "../../lib/topic-icon-tone";

interface Props {
  topicId: string;
  title: string;
  description: string;
  icon: string;
  colorVariant?: TopicVariant;
  headings: Array<{
    depth: number;
    slug: string;
    text: string;
  }>;
}

const {
  topicId,
  title,
  description,
  icon,
  colorVariant = "primary",
  headings,
} = Astro.props;

const iconToneClasses = getTopicIconToneClasses(topicId, colorVariant);
const haloToneClasses = getTopicHaloToneClasses(topicId, colorVariant);

const tocHeadings = headings.filter(
  (heading) =>
    (heading.depth === 2 || heading.depth === 3) &&
    heading.slug &&
    heading.text.trim().length > 0,
);
---

<SectionWrapper>
  <a href="/#syllabus" class="btn btn-ghost btn-sm w-fit">Volver al temario</a>
  {
    tocHeadings.length > 0 && (
      <details class="collapse collapse-arrow border border-base-300 bg-base-100 lg:hidden">
        <summary class="collapse-title py-3 text-base font-semibold">
          En esta pagina
        </summary>
        <div class="collapse-content pt-0">
          <nav aria-label="En esta pagina">
            <ul class="menu menu-sm p-0">
              {tocHeadings.map((heading) => (
                <li>
                  <a
                    href={`#${heading.slug}`}
                    class:list={[
                      "rounded-lg transition-colors hover:bg-neutral/10 hover:text-base-content",
                      heading.depth === 2
                        ? "px-3 py-2 text-sm font-semibold leading-snug text-base-content/80"
                        : "ml-3 px-3 py-1.5 text-sm leading-snug text-base-content/65",
                    ]}
                  >
                    {heading.text}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </div>
      </details>
    )
  }
  <div class="grid gap-8 lg:grid-cols-12">
    <div id="topic-content" class="min-w-0 space-y-8 lg:col-span-8">
      <header
        class="relative overflow-hidden rounded-3xl border border-base-300 bg-base-200/70 p-8 md:p-10"
      >
        <div
          aria-hidden="true"
          class={`absolute right-4 top-4 size-28 rounded-full blur-2xl ${haloToneClasses}`}
        >
        </div>
        <div
          class="relative z-10 flex flex-col items-start gap-4 sm:flex-row sm:items-center sm:gap-8"
        >
          <div class={`shrink-0 rounded-2xl p-4 shadow-sm ${iconToneClasses}`}>
            <Icon name={icon} aria-hidden="true" class="size-8" />
          </div>
          <div class="min-w-0">
            <h1
              id="topic-title"
              class="wrap-break-word font-display font-bold text-3xl md:text-5xl"
            >
              {title}
            </h1>
            <p class="mt-2 max-w-prose text-base-content/80">{description}</p>
          </div>
        </div>
      </header>

      <article class="card border border-base-300 bg-base-100 shadow-sm">
        <div class="card-body">
          <div
            data-math-content
            class="prose prose-base max-w-none prose-headings:scroll-mt-24 prose-headings:font-display prose-headings:text-base-content prose-p:text-base-content/85 prose-li:text-base-content/85 prose-strong:text-base-content prose-a:text-primary prose-table:text-sm prose-th:text-base-content prose-td:text-base-content/85"
          >
            <slot />
          </div>
        </div>
      </article>
    </div>

    <aside
      class="hidden lg:col-span-4 lg:block lg:sticky lg:top-24 lg:self-start"
    >
      <nav class="rounded-2xl" aria-label="En esta pagina">
        <div class="flex flex-col gap-4 lg:max-h-screen">
          <h2 class="card-title text-xl">En esta pagina</h2>
          {
            tocHeadings.length > 0 && (
              <ul class="menu p-0 lg:min-h-0 lg:flex-1 lg:overflow-y-auto">
                {tocHeadings.map((heading) => (
                  <li>
                    <a
                      href={`#${heading.slug}`}
                      class:list={[
                        "rounded-lg transition-colors hover:bg-neutral/10 hover:text-base-content",
                        heading.depth === 2
                          ? "px-3 py-2 text-sm font-semibold leading-snug text-base-content/80"
                          : "ml-3 px-3 py-1.5 text-sm leading-snug text-base-content/65",
                      ]}
                    >
                      {heading.text}
                    </a>
                  </li>
                ))}
              </ul>
            )
          }
        </div>
      </nav>
    </aside>
  </div>
</SectionWrapper>

<script is:inline>
  const scrollToCurrentHash = (behavior = "auto") => {
    const rawHash = window.location.hash;
    if (!rawHash) {
      return;
    }

    const targetId = decodeURIComponent(rawHash.slice(1));
    const targetElement = document.getElementById(targetId);

    if (!targetElement) {
      return;
    }

    targetElement.scrollIntoView({ behavior, block: "start" });
  };

  const bootHashScroll = () => {
    requestAnimationFrame(() => {
      scrollToCurrentHash("auto");
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", bootHashScroll, {
      once: true,
    });
  } else {
    bootHashScroll();
  }

  window.addEventListener("hashchange", () => {
    scrollToCurrentHash("smooth");
  });
</script>
