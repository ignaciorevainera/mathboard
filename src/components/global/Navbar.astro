---
import { Icon } from "astro-icon/components";
---

<div
  class="navbar sticky top-0 z-50 border-b border-base-300/70 bg-base-100/90 px-3 backdrop-blur md:px-4"
>
  <div class="navbar-start flex-0">
    <a
      href="/"
      class="btn btn-ghost btn-sm btn-circle"
      aria-label="Ir al inicio"
      title="Inicio"
    >
      <Icon name="hugeicons:home-02" aria-hidden="true" class="size-5" />
    </a>
  </div>

  <div class="navbar-center grow">
    <form
      role="search"
      action="/"
      method="get"
      class="flex justify-center w-full"
    >
      <label class="input">
        <Icon name="hugeicons:search-01" aria-hidden="true" class="size-4" />
        <input
          type="search"
          name="q"
          class="grow"
          placeholder="Buscar tema, formula o atajo"
          aria-label="Buscar contenido"
        />
      </label>
    </form>
  </div>

  <div class="navbar-end flex-0">
    <button
      type="button"
      class="btn btn-ghost btn-sm btn-circle"
      data-toggle-theme="light,night"
      data-key="mathboard-theme"
      data-act-class="btn-active"
      aria-label="Cambiar entre tema claro y oscuro"
      title="Cambiar tema"
    >
      <span class="dark:hidden" data-theme-icon-name="hugeicons:moon-02">
        <Icon name="hugeicons:moon-02" aria-hidden="true" class="size-5" />
      </span>
      <span class="hidden dark:inline" data-theme-icon-name="hugeicons:sun-03">
        <Icon name="hugeicons:sun-03" aria-hidden="true" class="size-5" />
      </span>
    </button>
  </div>
</div>
