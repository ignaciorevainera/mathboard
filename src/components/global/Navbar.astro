---
import { Icon } from "astro-icon/components";
---

<div
  class="navbar sticky top-0 z-50 border-b border-base-300/70 bg-base-100/90 px-3 backdrop-blur md:px-4"
>
  <div class="navbar-start flex-0">
    <a
      href="/"
      class="btn btn-ghost btn-sm btn-circle"
      aria-label="Ir al inicio"
      title="Inicio"
    >
      <Icon name="tabler:home-2" aria-hidden="true" class="size-5" />
    </a>
  </div>

  <div class="navbar-center grow">
    <form
      role="search"
      action="/"
      method="get"
      class="flex justify-center w-full"
    >
      <label class="input">
        <Icon name="tabler:search" aria-hidden="true" class="size-4" />
        <input
          type="search"
          name="q"
          class="grow"
          placeholder="Search topic, formula, or shortcut"
          aria-label="Search content"
        />
      </label>
    </form>
  </div>

  <div class="navbar-end flex-0">
    <button
      type="button"
      class="btn btn-ghost btn-sm btn-circle"
      data-toggle-theme="light,night"
      data-act-class="ACTIVECLASS"
      aria-label="Cambiar entre tema claro y oscuro"
      title="Cambiar tema"
    >
      <Icon name="tabler:contrast-filled" aria-hidden="true" class="size-5" />
    </button>
  </div>
</div>
