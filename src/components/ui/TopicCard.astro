---
import { Icon } from "astro-icon/components";
import { getTopicIconToneClasses } from "../../lib/topic-icon-tone";

interface Props {
  id: string;
  title: string;
  description: string;
  subtopicsCount: number;
  icon: string;
  colorVariant?: "primary" | "secondary" | "accent" | "neutral";
}

const {
  id,
  title,
  description,
  subtopicsCount,
  icon,
  colorVariant = "primary",
} = Astro.props;

const iconColorClasses = getTopicIconToneClasses(id, colorVariant);
---

<a
  href={`/topic/${id}/`}
  class="group card relative h-full cursor-pointer overflow-hidden border border-base-300 bg-base-200 shadow-sm transition-all duration-300 hover:-translate-y-1.5 hover:border-primary/40 hover:shadow-xl focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/50"
  aria-label={`Ingresar a ${title}`}
>
  <div class="card-body relative gap-3 p-4 sm:gap-4 sm:p-5">
    <div
      class={`w-fit rounded-xl p-2.5 shadow-sm transition-transform duration-300 group-hover:scale-105 sm:p-3 ${iconColorClasses}`}
    >
      <Icon name={icon} aria-hidden="true" class="size-5 sm:size-6" />
    </div>

    <div>
      <h3
        class="card-title mb-1 text-base font-bold leading-snug text-base-content sm:text-lg md:text-xl"
      >
        {title}
      </h3>
      <p
        class="min-h-0 text-xs leading-relaxed text-base-content/80 sm:min-h-20 sm:text-sm"
      >
        {description}
      </p>
    </div>

    <div
      class="card-actions mt-2 items-center justify-between border-t border-base-content/20 pt-3 sm:pt-4"
    >
      <span class="badge badge-soft badge-xs font-bold sm:badge-sm">
        {subtopicsCount} temas
      </span>
      <span
        class="inline-flex items-center gap-1 text-xs font-semibold text-base-content/80 transition-colors group-hover:text-primary sm:text-sm"
      >
        Ver tema
        <Icon
          name="tabler:arrow-right"
          aria-hidden="true"
          class="size-3.5 transition-transform duration-200 group-hover:translate-x-0.5 sm:size-4"
        />
      </span>
    </div>
  </div>
</a>
