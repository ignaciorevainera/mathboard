---
import { Icon } from "astro-icon/components";

interface Props {
  id: string;
  title: string;
  description: string;
  subtopicsCount: number;
  icon: string;
  colorVariant?: "primary" | "secondary" | "accent" | "neutral";
}

const {
  id,
  title,
  description,
  subtopicsCount,
  icon,
  colorVariant = "primary",
} = Astro.props;

const iconColorClassMap = {
  primary: "bg-primary/15 text-primary",
  secondary: "bg-secondary/15 text-secondary",
  accent: "bg-accent/15 text-accent",
  neutral: "bg-neutral/15 text-neutral",
};

const iconColorClasses = iconColorClassMap[colorVariant];
---

<article
  class="card h-full border border-base-300 bg-base-200 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg"
>
  <div class="card-body gap-4">
    <div class="flex items-start justify-between">
      <div class={`rounded-xl p-3 shadow-sm ${iconColorClasses}`}>
        <Icon name={icon} aria-hidden="true" class="size-6" />
      </div>
      <span class="badge badge-soft">{subtopicsCount} temas</span>
    </div>

    <h3 class="card-title text-xl">{title}</h3>
    <p class="text-sm text-base-content/80">{description}</p>

    <div class="card-actions mt-2 justify-end border-t border-base-300 pt-4">
      <a href={`/topic/${id}`} class="btn btn-ghost btn-sm gap-1">
        Ingresar
        <Icon name="tabler:arrow-right" aria-hidden="true" class="size-4" />
      </a>
    </div>
  </div>
</article>
