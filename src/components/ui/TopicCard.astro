---
import { Icon } from "astro-icon/components";

interface Props {
  id: string;
  title: string;
  description: string;
  subtopicsCount: number;
  icon: string;
  colorVariant?: "primary" | "secondary" | "accent" | "neutral";
}

const {
  id,
  title,
  description,
  subtopicsCount,
  icon,
  colorVariant = "primary",
} = Astro.props;

const iconColorClassMap = {
  primary: "bg-primary/15 text-primary",
  secondary: "bg-secondary/15 text-secondary",
  accent: "bg-accent/15 text-accent",
  neutral: "bg-neutral/15 text-neutral",
};

const iconColorClasses = iconColorClassMap[colorVariant];
---

<a
  href={`/topic/${id}/`}
  class="card group h-full cursor-pointer border border-base-300 bg-base-200 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/50"
  aria-label={`Ingresar a ${title}`}
>
  <div class="card-body gap-4">
    <div class={`w-fit rounded-xl p-3 shadow-sm ${iconColorClasses}`}>
      <Icon name={icon} aria-hidden="true" class="size-6" />
    </div>

    <h3 class="card-title text-xl">{title}</h3>
    <p class="text-sm text-base-content/80">{description}</p>

    <div
      class="card-actions mt-2 items-center justify-between border-t border-base-content/20 pt-4"
    >
      <span class="badge badge-soft">{subtopicsCount} temas</span>
      <span
        class="inline-flex items-center gap-1 text-sm font-medium text-base-content/80 transition-colors group-hover:text-primary"
      >
        Ingresar
        <Icon
          name="tabler:arrow-right"
          aria-hidden="true"
          class="size-4 transition-transform duration-200 group-hover:translate-x-0.5"
        />
      </span>
    </div>
  </div>
</a>
